{
  "manifest_version": 3,
  "name": "Focus Guard — Social Media Break Timer",
  "version": "1.0.0",
  "description": "Take mindful breaks from social media. Track your time, schedule breaks, and stay focused.",

  "permissions": [
    "storage",
    "tabs",
    "scripting",
    "alarms",
    "activeTab"
  ],

  "host_permissions": [
    "https://*.instagram.com/*",
    "https://*.facebook.com/*",
    "https://*.twitter.com/*",
    "https://*.x.com/*",
    "http://127.0.0.1/*",
    "http://localhost/*",
    "https://*/*"
  ], 

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": ["content.js"],
      "css": ["overlay.css", "cat-animation.css"],
      "run_at": "document_start"
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "web_accessible_resources": [
    {
      "resources": [
        "overlay.css",
        "cat-animation.css",
        "entitlements.js",
        "assets/astronaut-float.png",
        "assets/reset-mind-logo.png",
        "assets/dopamine-detox-logo.png",
        "assets/cat-stretch-logo.png",
        "assets/breath-break-art.png",
        "assets/were-cooked-logo.png"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
