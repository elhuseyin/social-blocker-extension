# ─── Copy to .env and fill in (never commit .env) ───────────────────────────

NODE_ENV=development
PORT=8787

# Stripe Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Dashboard → Products → Price IDs (one subscription, one one-time)
STRIPE_PRICE_SUBSCRIPTION=price_...
STRIPE_PRICE_ONETIME=price_...

# Public URL of this API (no trailing slash). Used for Checkout success/cancel redirects.
# Local: use ngrok/cloudflared HTTPS URL for webhooks; for quick local UI test you can use http://127.0.0.1:8787
PUBLIC_BASE_URL=http://127.0.0.1:8787

# Optional: require extension to send matching X-FocusGuard-Client header (set same value in extension billing-config.js)
BILLING_CLIENT_SECRET=

# Optional: seed a promo at server start if table empty (comma-separated)
# PROMO_SEED_CODES=EARLYBIRD2026:100,FRIENDPASS:50
